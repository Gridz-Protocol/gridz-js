    "test": "vitest run --coverage"
  },
  "dependencies": { "@gridz/core": "workspace:*" },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "oxlint": "^0.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
