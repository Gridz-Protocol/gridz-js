{
  "name": "@gridz/vue",
  "version": "0.1.0",
  "description": "Gridz Vue renderer.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external vue",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run --coverage"
  },
  "peerDependencies": { "vue": "^3.4.0" },
  "dependencies": { "@gridz/core": "workspace:*" },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "oxlint": "^0.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vue": "^3.5.13"
  }
}
