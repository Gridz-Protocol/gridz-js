{
  "name": "@gridz/sdk",
  "version": "0.1.0",
  "description": "Gridz high-level TypeScript SDK — typed client over the API plus core build/verify.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "gen:api": "openapi-typescript ../../specs/openapi.yaml -o src/openapi-types.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@gridz/core": "workspace:*"
  },
  "devDependencies": {
    "@gridz/server": "workspace:*",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "openapi-typescript": "^7.4.4",
    "oxlint": "^0.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
